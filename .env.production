# Production Environment Template
# Copy to .env and customize for your production environment

# PostgreSQL Configuration
# Change 'analyst' and 'analyst' to strong credentials
AL_DATABASE_URL=postgresql://analyst:change_me_strong_password@db:5432/analyst_lens

# JWT Secret Key for Authentication
# CRITICAL: Generate with: openssl rand -base64 32
# NEVER use the default value in production
AL_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# Session Token Expiration (minutes)
AL_ACCESS_TOKEN_EXPIRE_MINUTES=120

# Optional: OpenAI API Key (for AI-powered features)
# Leave blank if not using AI features
OPENAI_API_KEY=

# Database Admin Credentials (for docker-compose)
POSTGRES_USER=analyst
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=analyst_lens

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
API_BASE_URL=http://api:8000

# FastAPI Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

